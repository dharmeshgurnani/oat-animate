---
import { existsSync, statSync } from "node:fs";
import Clarity from "../components/Clarity.astro";

const {
  title = "Oat Animate",
  description = "Oat Animate is an ultra-lightweight CSS animation library for Oat that adds production-ready micro-interactions with simple ot-animate attributes.",
  robots = "index,follow",
  ogType = "website",
  ogImage = "/assets/logo.svg",
  ogImageAlt = "Oat Animate logo",
  structuredData = null,
} = Astro.props;
const activePath = Astro.url.pathname;
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL(ogImage, Astro.site ?? Astro.url).toString();
const isDev = import.meta.env.DEV;
const oatCss = isDev ? "/assets/oat-animate.css" : "/assets/oat-animate.min.css";
const oatJs = isDev ? "/assets/oat-animate.js" : "/assets/oat-animate.min.js";
const minJsPath = new URL("../../../dist/oat-animate.min.js", import.meta.url);
const minCssPath = new URL("../../../dist/oat-animate.min.css", import.meta.url);
const minJsGzPath = new URL("../../../dist/oat-animate.min.js.gz", import.meta.url);
const minCssGzPath = new URL("../../../dist/oat-animate.min.css.gz", import.meta.url);

function isActive(path) {
  return activePath === path;
}

function toKb(bytes) {
  return `${(bytes / 1024).toFixed(1)}kb`;
}

function getFileSize(pathUrl) {
  return existsSync(pathUrl) ? statSync(pathUrl).size : 0;
}

const totalMinBytes = getFileSize(minCssPath) + getFileSize(minJsPath);
const totalMinGzBytes = getFileSize(minCssGzPath) + getFileSize(minJsGzPath);

const minifiedSize = totalMinBytes > 0 ? toKb(totalMinBytes) : "--";
const minifiedGzSize = totalMinGzBytes > 0 ? toKb(totalMinGzBytes) : "--";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={`${title} | Oat Animate`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="Oat Animate" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Oat Animate`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <title>{title} | Oat Animate</title>
    <link rel="stylesheet" href="/assets/oat.min.css" />
    <link rel="stylesheet" href="/assets/github-dark.min.css" />
    <link rel="stylesheet" href="/assets/global.css" />
    <link rel="stylesheet" href={oatCss} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Oat Animate",
      url: Astro.site ?? "https://oat-animate.dharmeshgurnani.com",
      description,
      publisher: {
        "@type": "Person",
        name: "Dharmesh Gurnani",
        url: "https://www.dharmeshgurnani.com",
      },
    })} />
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
    
    <link rel="icon" href="/assets/favicon.ico" />
    <link rel="icon" type="image/png" href="/assets/logo.png" />
    <link rel="icon" type="image/x-icon" href="/assets/logo.ico" />
    <link rel="apple-touch-icon" href="/assets/logo.png" />
    <link rel="apple-touch-icon-precomposed" href="/assets/logo.png" />

  </head>
  <body>
    <div data-sidebar-layout="always">
      <nav data-topnav class="hstack">
        <img src="/assets/logo.svg" alt="Logo" width="100" height="40" />
      </nav>

      <aside data-sidebar>
        <nav>
          <ul>
            <li>
              <a href="https://github.com/dharmeshgurnani/oat-animate" target="_blank" rel="noreferrer">
                <img src="/assets/github.svg" alt="GitHub icon" /> GitHub
              </a>
            </li>
            <li><a href="/" aria-current={isActive("/") ? "page" : undefined}>Home</a></li>
            <li><a href="/usage" aria-current={isActive("/usage") ? "page" : undefined}>Usage</a></li>
            <li><a href="/customizing" aria-current={isActive("/customizing") ? "page" : undefined}>Customizing</a></li>
            <li>
              <details open>
                <summary>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                      <rect x="3" y="3" width="7" height="7"></rect>
                      <rect x="14" y="3" width="7" height="7"></rect>
                      <rect x="14" y="14" width="7" height="7"></rect>
                      <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                Animations</summary>
                <ul>
                  <li><a href="/animations#onload" aria-current={isActive("/animations#onload") ? "page" : undefined}>On load</a></li>
                  <li><a href="/animations#onhover" aria-current={isActive("/animations#onhover") ? "page" : undefined}>On hover</a></li>
                  <li><a href="/animations#inview" aria-current={isActive("/animations#inview") ? "page" : undefined}>In view</a></li>
                </ul>
              </details>
            </li>
          </ul>
        </nav>
        <footer>
         <div class="card mb-4 p-4 hstack" ot-animate="pop" style="margin-left:auto;gap:.5rem;">
          <small>minified: {minifiedSize}</small>
          <small>minified gz: {minifiedGzSize}</small>
        </div>
          <button class="w-100 outline small" onclick="toggleTheme()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-light">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-dark">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            Switch theme
          </button>
        </footer>
      </aside>

      <main class="wrap">
        <div class="container m-4 p-4">
          <slot />
        </div>
        <footer class="hstack p-4">
           <span class="p-4">👾
        <a class href="https://www.dharmeshgurnani.com&utm_source=oat-animate" target="_blank">
           @dharmeshgurnani
        </a>
        </span>
        </footer>
      </main>
    </div>

    <script src="/assets/oat.min.js" defer is:inline></script>
    <script src="/assets/global.js" is:inline></script>
    <script src={oatJs} is:inline></script>
    <script>
      import hljs from "highlight.js";

      const init = () => {
        if (window.OATAnimate) {
          window.OATAnimate.init();
        }
        document.querySelectorAll("pre code").forEach((el) => {
          hljs.highlightElement(el);
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    </script>
    <Clarity />
  </body>
</html>
