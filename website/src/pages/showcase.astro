  <script src="/assets/oat.min.js" is:inline></script>
  <script src={oatJs}></script>
  <script is:inline>
    const init = () => {
      if (window.OATAnimate) {
        window.OATAnimate.init();
      }

      // Universal Demo Modal Trigger
      const modal = document.getElementById('demo-modal');
      document.addEventListener('click', (e) => {
        const trigger = e.target.closest('a, button');
        if (trigger && !trigger.closest('dialog') && !trigger.hasAttribute('data-no-demo')) {
          e.preventDefault();
          modal.showModal();
        }
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  </script>
