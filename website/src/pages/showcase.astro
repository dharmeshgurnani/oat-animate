---
const isDev = import.meta.env.DEV;
const oatCss = isDev ? "/assets/oat-animate.css" : "/assets/oat-animate.min.css";
const oatJs = isDev ? "/assets/oat-animate.js" : "/assets/oat-animate.min.js";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WealthHub - Personal Investment Portal</title>
  
  <link rel="stylesheet" href="/assets/oat.min.css" />
  <link rel="stylesheet" href={oatCss} />

  <style is:inline>
    .terminal-header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: var(--background);
      backdrop-filter: blur(12px);
    }

    .terminal-metric__progress {
      height: 6px;
      background: var(--muted-10);
    }

    .terminal-performance__chart-container {
      min-height: 300px;
    }

    .terminal-performance__svg {
      overflow: visible;
    }

    .terminal-sector__progress {
      height: 8px;
    }

    .terminal-ledger__badge {
      border-radius: 8px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .terminal-risk__volatility-progress {
      height: 12px;
      border-radius: 6px;
    }

    .terminal-allocation__progress {
      height: 6px;
    }

    .terminal-rebalance__icon {
      border-radius: 50%;
      aspect-ratio: 1/1;
    }

    .terminal-tax__provision {
      min-width: 160px;
    }

    .terminal-tax__progress {
      height: 14px;
      border-radius: 7px;
      background: var(--muted-20);
    }

    .terminal-nodes__card {
      min-width: 100px;
    }

    .terminal-nodes__action {
      width: 100%;
      border-style: dashed;
    }

    .terminal-disclaimer {
      border: 1px solid var(--primary-20) !important;
    }

    .terminal-disclaimer__content {
      max-width: 450px;
    }

    .terminal-disclaimer__icon {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      font-size: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Progress Bar Widths */
    .w-85p { width: 85%; }
    .w-32p { width: 32.4%; }
    .w-24p { width: 24.8%; }
    .w-18p { width: 18.2%; }
    .w-12-5p { width: 12.5%; }
    .w-12p { width: 12.1%; }
    .w-30p { width: 30%; }
    .w-50p { width: 50%; }
    .w-20p { width: 20%; }
    .w-45p { width: 45%; }
    .w-15p { width: 15%; }
    .w-10p { width: 10%; }
    .w-82p { width: 82%; }

    /* Utility Helpers */
    .sticky-col {
      position: sticky;
      top: 6rem;
    }
  </style>
</head>
<body class="vstack gap-0 bg-background text-foreground">

  <!-- Navigation -->
  <header class="container border-b p-4 hstack justify-between terminal-header" ot-animate="view:fade-in">
      <div class="vstack gap-2">
        <div class="hstack gap-2 mb-0">
          <img src="/assets/logo.svg" alt="WealthHub" width="60" height="30" />
          <strong class="text-xl tracking-tight">Wealth Management Terminal</strong>
        </div>
        <div class="text-lighter text-sm">Institutional Grade Portfolio Analytics & Asset Management Interface.</div>
      </div>
  </header>

  <main class="vstack gap-10 p-8 container">
    <br/>
    <!-- Hero Personal Stats -->
    <section class="vstack gap-2" ot-animate="view:fade-up">
      <div class="hstack items-center gap-4">
        <h1 class="m-0 text-5xl font-bold">₹3,42,89,012 <span class="text-muted text-2xl font-normal">INR</span></h1>


        <div class="vstack gap-1">
          <span class="badge success outline">+12.4% Annualized Yield</span>
          <span class="text-lighter text-xs font-medium">Benchmark: Nifty 50 (+10.1%)</span>
        </div>
      </div>
    </section>

    <!-- Key Metrics Grid -->
    <section class="row gap-8 items-stretch">
      <article class="col col-4 hstack" ot-animate="view:fade-up delay-100">
        <div class="card p-6 vstack gap-4 flex-grow" ot-animate="hover:zoom-in">
          <div class="hstack justify-between">
            <h3 class="m-0 text-md font-bold">Direct Equity</h3>
            <span class="text-success text-sm font-mono">+₹1,02,240.50</span>
          </div>
          <div class="vstack gap-1">
            <h2 class="m-0">₹1,82,40,000</h2>
            <div class="hstack gap-2 items-center">
              <span class="text-lighter text-xs">Cost Basis: ₹1.42Cr</span>
              <span class="badge outline success small font-mono">22.4% Unrealized Gain</span>
            </div>
          </div>
          <div class="hstack gap-2 flex-wrap mt-auto">
            <span class="badge outline small">RELIANCE</span>
            <span class="badge outline small">TCS</span>
            <span class="badge outline small">HDFC BANK</span>
            <span class="text-lighter text-xs font-medium">+15 Instruments</span>
          </div>
        </div>
      </article>

      <article class="col col-4 hstack" ot-animate="view:fade-up delay-200">
        <div class="card p-6 vstack gap-4 flex-grow" ot-animate="hover:zoom-in">
          <div class="hstack justify-between">
            <h3 class="m-0 text-md font-bold">Fixed Income & Debt</h3>
            <span class="text-lighter text-sm font-mono">Mod Duration: 4.2Y</span>
          </div>
          <div class="vstack gap-1">
            <h2 class="m-0">₹94,11,218</h2>
            <p class="text-lighter text-xs">Weighted Average Yield to Maturity (YTM): 7.4%</p>
          </div>
          <div class="progress terminal-metric__progress">
            <div class="progress-bar bg-primary w-85p"></div>
          </div>
          <p class="text-lighter text-xs m-0 mt-auto">Liquidity Coverage: 85% of Reserve Target</p>
        </div>
      </article>

      <article class="col col-4 hstack" ot-animate="view:fade-up delay-300">
        <div class="card glass-card p-6 vstack gap-4 border-primary flex-grow" ot-animate="hover:zoom-in">
          <div class="hstack justify-between">
            <h3 class="m-0 text-md text-primary font-bold">Active Mandates</h3>

            <span class="badge primary outline small">Quant-SIP Active</span>
          </div>
          <div class="vstack gap-4">
            <h2 class="m-0 text-2xl">₹2,45,000</h2>
            <p class="text-lighter text-xs">Monthly Automated Deployment across Alpha Factors</p>
          </div>
          <div class="hstack gap-4 mt-auto">
            <button class="primary flex-grow">Review Mandates</button>
            <button class="outline">History</button>
          </div>
        </div>
      </article>
    </section>

    <br/>
    <!-- Performance & Insights -->
    <section class="row gap-8 items-stretch">
      <div class="col col-8 vstack gap-6" ot-animate="view:fade-up">
        <div class="hstack justify-between items-center">
          <h2 class="m-0 text-xl font-bold">Portfolio Performance Tracking</h2>
          <div class="hstack gap-4">
            <div class="hstack gap-2 items-center">
              <div class="badge primary small dot"></div>
              <span class="text-xs font-bold text-lighter">AuM Growth</span>
            </div>
            <div class="hstack gap-2 items-center">
              <div class="badge accent small dot"></div>
              <span class="text-xs font-bold text-lighter">Nifty 50</span>
            </div>
          </div>
        </div>
        <div class="card p-6 flex-grow bg-white vstack justify-center terminal-performance__chart-container">
          <svg viewBox="0 0 800 240" class="w-100 h-100 terminal-performance__svg">
            <!-- Grid Lines -->
            <line x1="0" y1="200" x2="800" y2="200" stroke="var(--muted-10)" stroke-width="1" />
            <line x1="0" y1="150" x2="800" y2="150" stroke="var(--muted-10)" stroke-width="1" />
            <line x1="0" y1="100" x2="800" y2="100" stroke="var(--muted-10)" stroke-width="1" />
            <line x1="0" y1="50" x2="800" y2="50" stroke="var(--muted-10)" stroke-width="1" />
            
            <!-- Nifty 50 Line (Benchmark) -->
            <path d="M 0 180 L 100 170 L 200 175 L 300 160 L 400 165 L 500 150 L 600 155 L 700 140 L 800 145" 
                  fill="none" stroke="var(--accent-40)" stroke-width="2" stroke-dasharray="4 2" />
            
            <!-- AuM Growth Line -->
            <path d="M 0 190 Q 50 185, 100 160 T 200 150 T 300 130 T 400 110 T 500 90 T 600 70 T 700 50 T 800 40" 
                  fill="none" stroke="var(--primary)" stroke-width="4" stroke-linecap="round" 
                  ot-animate="view:draw duration-2000" />
            
            <!-- Data Tooltip Point -->
            <circle cx="800" cy="40" r="6" fill="var(--primary)" stroke="white" stroke-width="3" />
          </svg>
          <div class="hstack justify-between mt-4 text-xs font-bold text-lighter px-2">
            <span>SEP 2025</span>
            <span>OCT 2025</span>
            <span>NOV 2025</span>
            <span>DEC 2025</span>
            <span>JAN 2026</span>
            <span>FEB 2026</span>
            <span>MAR 2026</span>
          </div>
        </div>
      </div>

      <div class="col col-4 vstack gap-6" ot-animate="view:fade-up delay-200">
        <h2 class="m-0 text-xl font-bold">Sector Exposure</h2>
        <div class="card p-6 flex-grow vstack gap-5 bg-muted-5">
          <div class="vstack gap-2">
            <div class="hstack justify-between text-xs font-bold">
              <span>Financial Services</span>
              <span>32.4%</span>
            </div>
            <div class="progress terminal-sector__progress"><div class="progress-bar bg-primary w-32p"></div></div>
          </div>
          <div class="vstack gap-2">
            <div class="hstack justify-between text-xs font-bold">
              <span>Information Tech</span>
              <span>24.8%</span>
            </div>
            <div class="progress terminal-sector__progress"><div class="progress-bar bg-primary w-24p"></div></div>
          </div>
          <div class="vstack gap-2">
            <div class="hstack justify-between text-xs font-bold">
              <span>Energy & Power</span>
              <span>18.2%</span>
            </div>
            <div class="progress terminal-sector__progress"><div class="progress-bar bg-primary w-18p"></div></div>
          </div>
          <div class="vstack gap-2">
            <div class="hstack justify-between text-xs font-bold">
              <span>Consumer Discretionary</span>
              <span>12.5%</span>
            </div>
            <div class="progress terminal-sector__progress"><div class="progress-bar bg-primary w-12-5p"></div></div>
          </div>
          <div class="vstack gap-2">
            <div class="hstack justify-between text-xs font-bold">
              <span>Healthcare</span>
              <span>12.1%</span>
            </div>
            <div class="progress terminal-sector__progress"><div class="progress-bar bg-primary w-12p"></div></div>
          </div>
          <div class="mt-auto pt-4 border-t border-dashed">
            <button class="small outline w-100">View Concentration Report</button>
          </div>
        </div>
      </div>
    </section>

    <br/>
    <!-- Professional Ledger & Health -->
    <section class="row gap-8 items-start">
      <div class="col col-7 vstack gap-6" ot-animate="view:fade-up">
        <div class="hstack justify-between items-center">
          <h2 class="m-0 text-xl font-bold">Unified Transaction Ledger</h2>
          <a href="#" class="text-sm font-semibold text-primary">Advanced Filtering →</a>
        </div>
        <div class="card p-0 overflow-hidden shadow-sm flex-grow" ot-animate="view:fade-up delay-100">
          <table class="m-0 border-0">
            <tbody class="text-sm">     
              <tr class="hover:bg-muted-5 transition">
                <td class="p-4 border-b">
                  <div class="hstack  items-center">
                    <div class="badge primary outline terminal-ledger__badge">⇆</div>
                    <div class="vstack gap-0">
                      <strong>Nifty 50 Index Fund</strong>
                      <span class="text-lighter text-xs">SIP Execution • Systematic Investment</span>
                    </div>
                  </div>
                </td>
                <td class="text-right border-b font-bold">-₹50,000.00</td>
                <td class="text-lighter text-right text-xs border-b">Yesterday</td>
              </tr>
              <tr class="hover:bg-muted-5 transition">
                <td class="p-4 border-b">
                  <div class="hstack gap-3 items-center">
                    <div class="badge primary outline p-2 terminal-ledger__badge">⇆</div>
                    <div class="vstack gap-0">
                      <strong>Gold ETF</strong>
                      <span class="text-lighter text-xs">Asset Reallocation • Limit Buy</span>
                    </div>
                  </div>
                </td>
                <td class="text-right p-4 border-b font-bold">-₹1,50,000.00</td>
                <td class="text-lighter text-right text-xs p-4 border-b">Feb 20, 2026</td>
              </tr>
              <tr class="hover:bg-muted-5 transition">
                <td class="p-4 border-b">
                  <div class="hstack gap-3 items-center">
                    <div class="badge success outline p-2 terminal-ledger__badge">↗</div>
                    <div class="vstack gap-0">
                      <strong>Rental Income</strong>
                      <span class="text-lighter text-xs">Property Yield • Commercial Lease</span>
                    </div>
                  </div>
                </td>
                <td class="text-right p-4 border-b text-success font-bold">+₹65,000.00</td>
                <td class="text-lighter text-right text-xs p-4 border-b">Feb 15, 2026</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Risk Analytics (Sticky Column) -->
      <div class="col col-5 vstack gap-6 sticky-col" ot-animate="view:fade-up delay-200">

        <h2 class="m-0 text-xl font-bold">Portfolio Risk Analytics</h2>
        <div class="vstack gap-4 flex-grow">
          <article class="card glass-card p-6 vstack gap-4" ot-animate="view:pop delay-300">

            <div class="hstack justify-between items-center">
              <div class="vstack gap-0">
                <span class="text-xs font-bold uppercase tracking-widest text-lighter">Beta (vs Nifty 50)</span>
                <strong class="text-xl">0.86</strong>
              </div>
              <div class="vstack gap-0 text-right">
                <span class="text-xs font-bold uppercase tracking-widest text-lighter">Sharpe Ratio</span>
                <strong class="text-xl text-success">1.94</strong>
              </div>
            </div>
            <div class="vstack gap-2 ">
              <span class="text-xs font-bold uppercase tracking-widest text-lighter">Volatility Exposure</span>
              <div class="progress terminal-risk__volatility-progress">
                <div class="progress-bar bg-success w-30p"></div>
                <div class="progress-bar bg-warning w-50p"></div>
                <div class="progress-bar bg-danger w-20p"></div>
              </div>
              <div class="hstack justify-between text-xs font-semibold">
                <span class="text-success">Low (30%)</span>
                <span class="text-warning">Med (50%)</span>
                <span class="text-danger">High (20%)</span>
              </div>
            </div>
          </article>

          <div class="card p-6 vstack gap-4 bg-muted-10 border-dashed" ot-animate="view:fade-up delay-500">
            <div class="hstack gap-2 items-center">
              <span class="badge primary small">INSIGHT</span>
              <h4 class="m-0 text-sm font-bold">Standard Deviation Alert</h4>
            </div>
            <p class="text-sm text-light m-0 leading-relaxed">
              Your portfolio concentration in <strong>Large-cap IT</strong> has increased by 12% following recent gains. Consider hedging via index puts or profit booking to align with your <strong>Risk Mandate</strong>.
            </p>
            <button class="small outline primary mt-2">Generate Risk Report</button>
          </div>
        </div>
      </div>
    </section>

    <br/>

    <!-- Advanced Diversification -->
    <section class="row gap-8 items-stretch">
      <!-- Asset Allocation Bento -->
      <div class="col col-8 vstack gap-6" ot-animate="view:fade-up">
        <h2 class="m-0 text-xl font-bold">Asset Diversification & Weighting</h2>
        <div class="row gap-8 flex-grow">
          <div class="col col-6 hstack">
            <div class="card w-100 p-6 min-h-100 vstack gap-4 bg-muted-5 flex-grow" ot-animate="hover:lift">
              <div class="hstack justify-between items-center">
                <span class="text-xs font-bold uppercase tracking-widest text-lighter">Current Allocation</span>
                <span class="badge outline small success">Target Range Adjusted</span>
              </div>
              <div class="vstack gap-3 flex-grow justify-center">
                <div class="vstack gap-1">
                  <div class="hstack justify-between text-xs font-bold">
                    <span>Equities (Domestic)</span>
                    <span>45%</span>
                  </div>
                  <div class="progress terminal-allocation__progress"><div class="progress-bar bg-primary w-45p"></div></div>
                </div>
                <div class="vstack gap-1">
                  <div class="hstack justify-between text-xs font-bold">
                    <span>Debt & Bonds</span>
                    <span>30%</span>
                  </div>
                  <div class="progress terminal-allocation__progress"><div class="progress-bar bg-accent w-30p"></div></div>
                </div>
                <div class="vstack gap-1">
                  <div class="hstack justify-between text-xs font-bold">
                    <span>Alternate Assets (AIF/Gold)</span>
                    <span>15%</span>
                  </div>
                  <div class="progress terminal-allocation__progress"><div class="progress-bar bg-success w-15p"></div></div>
                </div>
                <div class="vstack gap-1">
                  <div class="hstack justify-between text-xs font-bold">
                    <span>Liquid Funds & Cash</span>
                    <span>10%</span>
                  </div>
                  <div class="progress terminal-allocation__progress"><div class="progress-bar bg-lighter w-10p"></div></div>
                </div>
              </div>
              <div class="divider border-dashed m-0 mt-4 pt-2"></div>
              <div class="hstack justify-between font-bold text-xs uppercase tracking-tighter opacity-80">
                <span>Total Capital Allocated</span>
                <span>100.0%</span>
              </div>
            </div>
          </div>
          <div class="col col-6 vstack gap-8">
            <div class="card p-6 vstack justify-center items-center text-center bg-primary text-white flex-grow" ot-animate="hover:zoom-in">
              <span class="text-xs uppercase font-bold tracking-widest opacity-80 mb-2">Investment Discipline</span>
              <h3 class="m-0 text-2xl">Balanced Growth</h3>
              <p class="text-xs mt-2 opacity-80">Max Drawdown: -12.4% annually</p>
            </div>
            <article class="card p-5 vstack justify-center bg-muted-10 flex-grow" ot-animate="hover:lift">
              <div class="hstack gap-3 items-center">
                <div class="badge primary terminal-rebalance__icon">⚙</div>
                <div class="vstack gap-0">
                  <strong class="text-sm">Active Rebalancing</strong>
                  <span class="text-lighter text-xs">Drift Threshold: 5.0%</span>
                </div>
              </div>
            </article>
          </div>
        </div>
      </div>
     
      <!-- Income Calendar (Professional Layout) -->
      <div class="col col-4 vstack gap-4" ot-animate="view:fade-up delay-100">
        <h2 class="m-0 text-xl font-bold">Liquidity Calendar</h2>
        <div class="card p-0 overflow-hidden shadow-sm flex-grow vstack">
          <div class="py-4 border-b bg-muted-5">
            <span class="text-xs font-bold text-lighter tracking-widest uppercase">Upcoming Cash Inflows</span>
          </div>
          <div class="vstack flex-grow">
            <div class="py-4 border-b hstack justify-between items-center hover:bg-muted-10 transition">
              <div class="vstack gap-0">
                <strong class="text-sm">TCS Equity • Dividend</strong>
                <span class="text-xs text-lighter">Ex-Date: Mar 08 | Pay: Mar 12</span>
              </div>
              <span class="text-success font-bold text-md">₹4,250</span>
            </div>
            <div class="py-4 border-b hstack justify-between items-center hover:bg-muted-10 transition">
              <div class="vstack gap-0">
                <strong class="text-sm">HDFC Term Dep • Interest</strong>
                <span class="text-xs text-lighter">Maturity: Mar 18 | Roll-over</span>
              </div>
              <span class="text-success font-bold text-md">₹18,400</span>
            </div>
            <div class="py-4 hstack justify-between items-center hover:bg-muted-10 transition">
              <div class="vstack gap-0">
                <strong class="text-sm">ICICI Gilt • Coupon</strong>
                <span class="text-xs text-lighter">Semi-Annual Payout: Apr 02</span>
              </div>
              <span class="text-success font-bold text-md">₹6,800</span>
            </div>
          </div>
          <div class="p-5 bg-success-20 text-center border-t border-success-40 mt-auto">
            <span class="text-sm font-bold text-success uppercase tracking-widest">Total Projected (30D): ₹29,450</span>
          </div>
        </div>
      </div>
    </section>
    <br class="p-4"/>

    <!-- Compliance & Nodes -->
    <section class="row gap-8 items-stretch">
      <!-- Tax & Compliance -->
      <div class="col col-7 vstack gap-6" ot-animate="view:fade-up delay-200">
        <h2 class="m-0 text-xl font-bold">Tax Compliance Hub (FY 2025-26)</h2>
        <div class="card p-6 hstack gap-8 items-center bg-muted-10 border-primary flex-grow">
          <div class="vstack gap-1 terminal-tax__provision">
            <span class="text-xs font-bold text-lighter uppercase tracking-widest">80C Tax Provision</span>
            <h3 class="m-0 text-2xl font-bold">₹1,24,000</h3>
            <span class="text-xs text-lighter">Available Limit: ₹26,000</span>
          </div>
          <div class="vstack gap-3 flex-grow">
            <div class="progress terminal-tax__progress">
              <div class="progress-bar bg-primary w-82p"></div>
            </div>
            <div class="hstack justify-between items-center mt-1">
              <div class="hstack gap-4">
                <div class="hstack gap-2 items-center">
                  <div class="badge primary small dot"></div>
                  <span class="text-xs font-bold">EPF / PPF</span>
                </div>
                <div class="hstack gap-2 items-center">
                  <div class="badge outline small dot"></div>
                  <span class="text-xs font-bold">ELSS</span>
                </div>
              </div>
              <a href="#" class="text-xs font-bold text-primary text-underline">Maximize Limit →</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Data Connectivity -->
      <div class="col col-5 vstack gap-6" ot-animate="view:fade-up delay-300">
        <h2 class="m-0 text-xl font-bold">Node Connectivity Status</h2>
        <div class="card p-5 vstack gap-4 bg-muted-5 flex-grow">
          <div class="hstack gap-3 flex-wrap justify-between flex-grow">
            <div class="vstack items-center justify-center gap-2 p-3 bg-white rounded shadow-sm flex-grow terminal-nodes__card">
              <span class="text-xs font-bold">HDFC BANK</span>
              <span class="badge success small outline px-2">LIVE</span>
            </div>
            <div class="vstack items-center justify-center gap-2 p-3 bg-white rounded shadow-sm flex-grow terminal-nodes__card">
              <span class="text-xs font-bold">ZERODHA KITE</span>
              <span class="badge success small outline px-2">LIVE</span>
            </div>
            <div class="vstack items-center justify-center gap-2 p-3 bg-white rounded shadow-sm flex-grow terminal-nodes__card">
              <span class="text-xs font-bold">ZERODHA COIN</span>
              <span class="badge warning small outline px-2">SYNCING</span>
            </div>
          </div>
          <button class="outline small px-4 py-3 bg-white text-lighter text-xs font-bold mt-4 terminal-nodes__action">
            + EXPLORE MORE CONNECTORS
          </button>
        </div>
      </div>
    </section>
